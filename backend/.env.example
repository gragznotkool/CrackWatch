# Backend secrets — copy to `backend/.env` and fill in. NEVER commit the real .env.

# Roboflow hosted inference API key. Get one at https://app.roboflow.com (Settings > API).
ROBOFLOW_API_KEY=

# JWT signing secret. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left unset, the app generates a random per-process secret (tokens reset on restart).
JWT_SECRET_KEY=

# Twilio auth token (optional, for SMS notifications).
TWILIO_AUTH_TOKEN=
